# GeoServer Konfigürasyon Değişkenleri
# Bu dosyayı kendi ortamınıza göre düzenleyin

# GeoServer Ayarları
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver_password_change_me

# JVM Memory Ayarları (GB cinsinden)
# Toplam RAM'in yaklaşık %50-70'i olmalı
INITIAL_MEMORY=4G
MAXIMUM_MEMORY=8G

# PostgreSQL Ayarları
POSTGRES_DB=geoserver
POSTGRES_USER=geoserver
POSTGRES_PASSWORD=postgres_password_change_me

# GeoServer Port
GEOSERVER_PORT=8080

# Nginx Port
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Timezone
TZ=Europe/Istanbul

# GDAL Ayarları
GDAL_CACHEMAX=512
GDAL_DATA=/usr/share/gdal

# GeoWebCache
TILE_CACHE_DIR=/opt/geoserver/data_dir/gwc

# Eklentiler (virgülle ayrılmış)
STABLE_EXTENSIONS=vectortiles-plugin,charts-plugin,css-plugin,mbstyle-plugin,wps-plugin,importer-plugin,gdal-plugin,oracle-plugin

# Community Eklentiler (isteğe bağlı)
# COMMUNITY_EXTENSIONS=

# Monitoring ve Loglama
GEOSERVER_LOG_LEVEL=PRODUCTION_LOGGING.xml
